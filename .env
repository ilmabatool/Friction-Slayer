PORT=3000
SESSION_SECRET=friction-secret

# Optional: add your Google PageSpeed Insights API key for higher rate limits
# Get one free at: https://developers.google.com/speed/docs/insights/v5/get-started
GOOGLE_PAGESPEED_API_KEY=REPLACE_WITH_YOUR_PAGESPEED_API_KEY
PAGESPEED_API_KEY=REPLACE_WITH_YOUR_PAGESPEED_API_KEY

GA4_PROPERTY_ID=REPLACE_WITH_YOUR_GA4_PROPERTY_ID

# Optional: Resend API key for email automation
# Get a free key at: https://resend.com
RESEND_API_KEY=REPLACE_WITH_YOUR_RESEND_API_KEY

GOOGLE_CLIENT_ID=REPLACE_WITH_YOUR_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_YOUR_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback