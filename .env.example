# ── Friction-Slayer · Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values, then run: node app.js

# Port the Express server listens on (default: 3000)
PORT=3000
SESSION_SECRET=replace-with-strong-random-secret

# Google OAuth credentials (required)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Google Analytics 4 property (required for true analytics-from-start)
GA4_PROPERTY_ID=123456789

# Optional: Google PageSpeed Insights API key for higher rate limits / real data
# Get a free key at: https://developers.google.com/speed/docs/insights/v5/get-started
GOOGLE_PAGESPEED_API_KEY=your-pagespeed-api-key
PAGESPEED_API_KEY=your-pagespeed-api-key

# Optional: Resend API key for future email-report feature
# Get a free key at: https://resend.com
RESEND_API_KEY=your-resend-api-key
